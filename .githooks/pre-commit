#!/bin/sh
#
# pre-commit hook: auto-update footer "Updated: ..." date on production HTML files.
#
# Touches any staged file under site/ that contains a <span class="footer-updated">
# element. Rewrites the date inside the span to today's date and re-stages the file.
#
# Activation (one-time per clone):
#   git config core.hooksPath .githooks
#
# See E:\TecVooDoo\Projects\Documents\Canonical\Web\TecVooDoo_Web_Workflow.md
# (Footer Updates section) for the rule this hook enforces.
#
# Installed: 2026-05-22

set -e

# ---------------------------------------------------------------------------
# Secret scan (added 2026-05-31 after the Resend API key leak).
# Dependency-free: blocks staged files by name pattern and scans staged
# content for known credential token shapes. If gitleaks is on PATH it also
# runs `gitleaks protect --staged` as a second, broader layer.
# Override an intentional commit with: git commit --no-verify
# ---------------------------------------------------------------------------
secret_hit=0

staged=$(git diff --cached --name-only --diff-filter=ACM || true)

for f in $staged; do
    # This hook itself contains the detection signatures -- never scan it.
    if [ "$f" = ".githooks/pre-commit" ]; then
        continue
    fi
    base=$(basename "$f")
    case "$base" in
        .env|*.env|*.key|*.pem|credentials*.json|*secret*.txt)
            echo "pre-commit: BLOCKED secret-file name: $f" >&2
            secret_hit=1
            continue
            ;;
    esac
    case "$base" in
        *API*.txt)
            echo "pre-commit: BLOCKED secret-file name: $f" >&2
            secret_hit=1
            continue
            ;;
    esac
    # Scan the staged blob content for credential token shapes.
    # Match credential token VALUES (high-entropy shapes), not header/field
    # names like "xi-api-key" -- those are noisy false positives in docs/config.
    if git show ":$f" 2>/dev/null | grep -Eq 're_[A-Za-z0-9_-]{20,}|sk_[A-Za-z0-9]{32,}|sk-[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----'; then
        echo "pre-commit: BLOCKED likely secret in content: $f" >&2
        secret_hit=1
    fi
done

if command -v gitleaks >/dev/null 2>&1; then
    if ! gitleaks protect --staged --no-banner >/dev/null 2>&1; then
        echo "pre-commit: BLOCKED by gitleaks (staged secret detected)" >&2
        secret_hit=1
    fi
fi

if [ "$secret_hit" -ne 0 ]; then
    echo "pre-commit: secret scan failed -- commit aborted. Use 'git commit --no-verify' to override if this is a false positive." >&2
    exit 1
fi

# Date format: "Mon D, YYYY" with non-padded day (e.g., "May 22, 2026", "Jan 4, 2026").
# %-d is GNU-only; fall back by stripping a leading zero from %d.
today=$(date +"%b %-d, %Y" 2>/dev/null || date +"%b %d, %Y" | sed 's/ 0/ /')

# Get staged (Added/Copied/Modified) HTML files under site/.
files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^site/.*\.html$' || true)

if [ -z "$files" ]; then
    exit 0
fi

for f in $files; do
    # Skip files that don't have the footer span (e.g., auth-test.html, dlyh wrapper).
    if ! grep -q '<span class="footer-updated">Updated:' "$f"; then
        continue
    fi

    # Replace the existing date with today's. sed -i with a backup suffix is the
    # portable form across GNU and BSD sed; we remove the .bak immediately.
    if sed -i.bak -E "s|(<span class=\"footer-updated\">Updated:)[^<]*(</span>)|\1 ${today}\2|" "$f"; then
        rm -f "${f}.bak"
        git add "$f"
        echo "pre-commit: footer date -> $today  ($f)"
    else
        rm -f "${f}.bak"
        echo "pre-commit: WARNING failed to rewrite footer in $f" >&2
    fi
done

exit 0
